webApp = container "Web App" "Customer, franchise and back-office UI" "React SPA" {
    tags "Frontend" "Web" "TechReact"
}

mobileClientApp = container "Customer Mobile App" "Ordering, tracking and customer account" "React Native Mobile App" {
    tags "Frontend" "Mobile" "TechReactNative"
}

mobileCourierApp = container "Courier Mobile App" "Assignments, navigation and delivery proof" "React Native Mobile App" {
    tags "Frontend" "Mobile" "TechReactNative"
}
