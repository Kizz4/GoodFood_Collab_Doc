webApp = container "Application Web" "Interface client, franchisé et back-office" "React" {
    tags "Frontend" "Web"
}

mobileClientApp = container "App Mobile Client" "Commande, suivi et compte client" "React Native" {
    tags "Frontend" "Mobile"
}

mobileCourierApp = container "App Mobile Livreur" "Missions, navigation et confirmation de livraison" "React Native" {
    tags "Frontend" "Mobile"
}
