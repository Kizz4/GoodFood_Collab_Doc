goodFood.apiGateway -> goodFood.customerService.customerApi "Routes customer calls" "REST/HTTPS"
goodFood.apiGateway -> goodFood.catalogueService.catalogueApi "Routes catalogue calls" "REST/HTTPS"
goodFood.apiGateway -> goodFood.orderService.orderApi "Routes order calls" "REST/HTTPS"
