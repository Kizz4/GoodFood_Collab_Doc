goodFood.notificationService.notificationDomain -> goodFood.notificationService.emailAdapter "Delegate outbound delivery" "In-process"
goodFood.notificationService.notificationRepo -> goodFood.notificationDb "Store templates and traces" "PostgreSQL"
goodFood.notificationService.emailAdapter -> sendGridApi "API calls" "HTTPS"
goodFood.notificationService.emailAdapter -> twilioApi "API calls" "HTTPS"
goodFood.notificationService.emailAdapter -> firebaseFcm "API calls" "HTTPS"

goodFood.integrationHub.eventConsumers -> goodFood.messageBroker "Consumes integration and store sync events" "AMQP"
goodFood.integrationHub.eventConsumers -> goodFood.integrationHub.integrationRepo "Store state" "In-process"
goodFood.integrationHub.eventConsumers -> goodFood.integrationHub.dynamicsAdapter "Delegate external exchange" "In-process"
goodFood.integrationHub.integrationRepo -> goodFood.integrationDb "Store integration state" "PostgreSQL"
