goodFood.customerService.customerApi -> goodFood.customerService.customerDomain "Expose" "In-process"
goodFood.customerService.customerDomain -> goodFood.customerService.customerRepo "Persist" "In-process"
goodFood.customerService.customerRepo -> goodFood.customerDb "Store profiles" "PostgreSQL"

goodFood.catalogueService.catalogueApi -> goodFood.catalogueService.catalogueDomain "Expose resolved catalog reads" "In-process"
goodFood.catalogueService.catalogueEventConsumer -> goodFood.messageBroker "Consumes product, override, and promotion events" "AMQP"
goodFood.catalogueService.catalogueEventConsumer -> goodFood.catalogueService.catalogueDomain "Consume catalog update events" "In-process"
goodFood.catalogueService.catalogueDomain -> goodFood.catalogueService.catalogueRepo "Persist resolved catalog views" "In-process"
goodFood.catalogueService.catalogueDomain -> goodFood.messageBroker "Publish resolved catalog updates" "AMQP"
goodFood.catalogueService.catalogueDomain -> goodFood.cacheRedis "Read/write resolved store catalog views" "Redis"
goodFood.catalogueService.catalogueRepo -> goodFood.catalogueDb "Store resolved store catalog views" "PostgreSQL"

goodFood.orderService.orderApi -> goodFood.orderService.orderDomain "Expose" "In-process"
goodFood.orderService.orderEventConsumer -> goodFood.messageBroker "Consumes catalog snapshot, preparation, and payment events" "AMQP"
goodFood.orderService.orderEventConsumer -> goodFood.orderService.orderDomain "Refresh local checkout references" "In-process"
goodFood.orderService.orderDomain -> goodFood.orderService.orderRepo "Load checkout references and persist orders" "In-process"
goodFood.orderService.orderRepo -> goodFood.orderDb "Store orders and checkout references" "PostgreSQL"
goodFood.orderService.orderDomain -> goodFood.messageBroker "Publish order events" "AMQP"

goodFood.complaintService.complaintApi -> goodFood.complaintService.complaintDomain "Expose" "In-process"
goodFood.complaintService.complaintDomain -> goodFood.complaintService.complaintRepo "Persist" "In-process"
goodFood.complaintService.complaintRepo -> goodFood.complaintDb "Store complaints" "PostgreSQL"
goodFood.complaintService.complaintDomain -> goodFood.messageBroker "Publish complaint events" "AMQP"

goodFood.localAssortmentService.localAssortmentApi -> goodFood.localAssortmentService.localAssortmentDomain "Expose local assortment ops" "In-process"
goodFood.localAssortmentService.localAssortmentDomain -> goodFood.localAssortmentService.localAssortmentRepo "Persist local assortment and promotion rules" "In-process"
goodFood.localAssortmentService.localAssortmentRepo -> goodFood.localAssortmentDb "Store local assortment and promotion rules" "PostgreSQL"
goodFood.localAssortmentService.localAssortmentDomain -> goodFood.messageBroker "Publish local assortment events" "AMQP"

goodFood.supplierService.supplierApi -> goodFood.supplierService.supplierDomain "Expose supplier ops" "In-process"
goodFood.supplierService.supplierDomain -> goodFood.supplierService.supplierRepo "Persist supplier and sourcing rules" "In-process"
goodFood.supplierService.supplierRepo -> goodFood.supplierDb "Store suppliers and sourcing rules" "PostgreSQL"
goodFood.supplierService.supplierDomain -> goodFood.messageBroker "Publish supplier sync events" "AMQP"

goodFood.preparationService.preparationApi -> goodFood.preparationService.preparationDomain "Expose preparation ops" "In-process"
goodFood.preparationService.preparationEventConsumer -> goodFood.messageBroker "Consumes order and payment lifecycle events" "AMQP"
goodFood.preparationService.preparationEventConsumer -> goodFood.preparationService.preparationDomain "Consume preparation triggers" "In-process"
goodFood.preparationService.preparationDomain -> goodFood.preparationService.preparationRepo "Persist preparation workflow" "In-process"
goodFood.preparationService.preparationRepo -> goodFood.preparationDb "Store preparation workflow" "PostgreSQL"
goodFood.preparationService.preparationDomain -> goodFood.messageBroker "Publish preparation events" "AMQP"

goodFood.paymentService.paymentApi -> goodFood.paymentService.paymentDomain "Expose" "In-process"
goodFood.paymentService.paymentEventConsumer -> goodFood.messageBroker "Consumes payment commands" "AMQP"
goodFood.paymentService.paymentEventConsumer -> goodFood.paymentService.paymentDomain "Consume payment commands" "In-process"
goodFood.paymentService.paymentDomain -> goodFood.paymentService.paymentProviderAdapter "Call BNB / PSP" "In-process"
